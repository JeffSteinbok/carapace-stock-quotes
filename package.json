{
  "name": "carapace-stock-quotes",
  "version": "1.3.0",
  "description": "Stock, ETF, and mutual fund quotes for OpenClaw \u2014 powered by Yahoo Finance and Finnhub",
  "repository": "github:JeffSteinbok/carapace-stock-quotes",
  "type": "module",
  "bin": {
    "stock-quotes": "./dist/bin/stock-quotes.js"
  },
  "scripts": {
    "build": "tsup && carapace-generate-cli --entry ./dist/plugin.js --out ./dist/bin",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "carapace",
    "plugin",
    "stocks",
    "finance",
    "quotes"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "carapace-plugin-sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.3.0",
    "typescript": "^5.7",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.23"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/adapter.js"
    ]
  },
  "license": "MIT"
}
